# Neon PostgreSQL — use the pooled connection string for the app
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection, required by Prisma Migrate
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# 32+ random chars. Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-secret"

# Vercel Blob (Storage tab -> Create store -> copy token)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
